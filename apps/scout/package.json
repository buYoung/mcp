{
    "name": "@buyong-mcp/scout",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "bin": {
        "scout": "./dist/index.js"
    },
    "main": "./dist/index.js",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "dev": "tsx watch src/index.ts",
        "start": "node dist/index.js",
        "check-types": "tsc -p tsconfig.json --noEmit",
        "inspect": "mcp-inspector tsx src/index.ts",
        "inspect:built": "mcp-inspector node dist/index.js"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "globby": "^14.1.0",
        "smol-toml": "^1.6.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@modelcontextprotocol/inspector": "^0.21.2",
        "@repo/typescript-config": "workspace:*",
        "@types/node": "^25.7.0",
        "tsx": "^4.21.0",
        "typescript": "6.0.3"
    },
    "engines": {
        "node": ">=18"
    }
}
