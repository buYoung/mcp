    "text": "function ActionMenu({\n  items,\n  onChoose,\n}: {\n  items: MenuItem[];\n  onChoose(id: string): void;\n}) {\n  const visible = useMemo(() => items.filter((item) => item.enabled), [items]);\n\n  return (\n    <nav>\n      {visible.map((item) => (\n        <button key={item.id} onClick={() => onChoose(item.id)}>\n          {item.label}\n        </button>\n      ))}\n    </nav>\n  );\n}",
