    "capture": "definition.function",
    "text": "function OrderTable({\n  items,\n  onSelect,\n}: {\n  items: LineItem[];\n  onSelect(id: string): void;\n}) {\n  const rows = useMemo(\n    () =>\n      items.map((item) => ({\n        id: item.id,\n        label: formatMoney(item.amount),\n      })),\n    [items],\n  );\n\n  return (\n    <section>\n      {rows.map((row) => (\n        <button key={row.id} onClick={() => onSelect(row.id)}>\n          {row.label}\n        </button>\n      ))}\n    </section>\n  );\n}",
