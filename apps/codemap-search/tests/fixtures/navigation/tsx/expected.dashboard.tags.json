    "text": "function OrderDashboard({ client }: { client: OrderClient }) {\n  const [orders, setOrders] = useState<OrderSummary[]>([]);\n\n  useEffect(() => {\n    client.load().then((items) => setOrders(items));\n  }, [client]);\n\n  return (\n    <ul>\n      {orders.map((order) => (\n        <li key={order.id}>{order.status}</li>\n      ))}\n    </ul>\n  );\n}",
