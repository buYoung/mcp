    "text": "class OrderPolicy {\n    private final List<Rule> rules;\n\n    OrderPolicy(List<Rule> rules) {\n        this.rules = rules;\n    }\n\n    List<String> evaluate(Order order) {\n        List<String> failures = rules.stream()\n                .filter(rule -> !rule.check(order))\n                .map(Rule::name)\n                .toList();\n        if (failures.isEmpty()) {\n            return List.of();\n        }\n        return failures;\n    }\n}",
