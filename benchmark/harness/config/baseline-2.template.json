{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama-cloud/deepseek-v4-flash",
  "provider": {
    "ollama-cloud": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama Cloud",
      "options": {
        "baseURL": "https://ollama.com/v1"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "deepseek-v4-flash",
          "limit": {
            "context": 1048576,
            "output": 1048576
          }
        }
      }
    }
  },
  "permission": {
    "external_directory": "deny",
    "bash": "deny",
    "task": "deny",
    "webfetch": "deny",
    "websearch": "deny"
  },
  "mcp": {
    "codemap_search": {
      "type": "local",
      "enabled": true,
      "command": ["__CODEMAP_SEARCH_BINARY__", "mcp"]
    }
  }
}
