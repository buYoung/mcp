{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "baseline-3x-aggregate-metrics.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "generation_id", "aggregation_contract", "attempt_accounting",
    "raw_sessions", "task_arm_rows", "paired_deltas", "task_delta_summaries", "overall_deltas",
    "judgment_agreement", "quality_rates", "behavior_rates", "navigation_behavior",
    "quality_cost_flags", "variance_warnings", "metric_catalog", "input_provenance"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "generation_id": {"type": "string", "minLength": 1},
    "aggregation_contract": {
      "type": "object",
      "required": ["session_count", "task_count", "trial_ids", "arms", "judgments_per_output", "delta_direction"],
      "properties": {
        "session_count": {"const": 84},
        "task_count": {"const": 14},
        "trial_ids": {"const": ["r1", "r2", "r3"]},
        "arms": {"const": ["B1", "B2"]},
        "judgments_per_output": {"const": 3},
        "delta_direction": {"const": "B2-B1"}
      }
    },
    "attempt_accounting": {"$ref": "#/$defs/attempt_accounting"},
    "raw_sessions": {"type": "array", "minItems": 84, "maxItems": 84, "items": {"$ref": "#/$defs/raw_session"}},
    "task_arm_rows": {"type": "array", "minItems": 28, "maxItems": 28, "items": {"$ref": "#/$defs/task_arm_row"}},
    "paired_deltas": {"type": "array", "minItems": 42, "maxItems": 42, "items": {"$ref": "#/$defs/paired_row"}},
    "task_delta_summaries": {"type": "array", "minItems": 14, "maxItems": 14, "items": {"type": "object"}},
    "overall_deltas": {"type": "object"},
    "judgment_agreement": {
      "type": "object",
      "required": ["outputs", "summary"],
      "properties": {
        "outputs": {"type": "array", "minItems": 84, "maxItems": 84},
        "summary": {"type": "object", "required": ["output_count"]}
      }
    },
    "quality_rates": {"$ref": "#/$defs/arm_section"},
    "behavior_rates": {"$ref": "#/$defs/arm_section"},
    "navigation_behavior": {"$ref": "#/$defs/arm_section"},
    "quality_cost_flags": {"type": "array"},
    "variance_warnings": {"type": "array"},
    "metric_catalog": {
      "type": "object",
      "required": ["numeric", "tool_families_observed", "quality_labels_rates_and_format_are_separate"],
      "properties": {"numeric": {"type": "array", "minItems": 1}}
    },
    "input_provenance": {
      "type": "object",
      "required": [
        "analysis_input_seal", "generation", "ledger", "automatic_schema", "metrics_index", "metrics",
        "coordinator_mapping", "scoring_manifest", "judgments_index", "judgments", "rubric", "answer_contracts"
      ],
      "properties": {
        "metrics": {"type": "array", "minItems": 84, "maxItems": 84},
        "judgments": {"type": "array", "minItems": 252, "maxItems": 252},
        "answer_contracts": {"type": "array", "minItems": 14, "maxItems": 14}
      }
    }
  },
  "$defs": {
    "nonnegative_integer": {"type": "integer", "minimum": 0},
    "attempt_accounting": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_attempt_count", "latest_valid_count", "superseded_attempt_count", "invalid_attempt_count",
        "transient_attempt_count", "replacement_attempt_count", "overall", "by_arm"
      ],
      "properties": {
        "raw_attempt_count": {"$ref": "#/$defs/nonnegative_integer"},
        "latest_valid_count": {"const": 84},
        "superseded_attempt_count": {"$ref": "#/$defs/nonnegative_integer"},
        "invalid_attempt_count": {"$ref": "#/$defs/nonnegative_integer"},
        "transient_attempt_count": {"$ref": "#/$defs/nonnegative_integer"},
        "replacement_attempt_count": {"$ref": "#/$defs/nonnegative_integer"},
        "overall": {"type": "object"},
        "by_arm": {"type": "array", "minItems": 2, "maxItems": 2}
      }
    },
    "raw_session": {
      "type": "object",
      "required": ["task_id", "trial_id", "arm", "run_id", "automatic_metric_record_kind", "automatic_metrics", "judgment_agreement"],
      "properties": {
        "trial_id": {"enum": ["r1", "r2", "r3"]},
        "arm": {"enum": ["B1", "B2"]},
        "automatic_metric_record_kind": {"const": "extractor_record"}
      }
    },
    "task_arm_row": {
      "type": "object",
      "required": ["task_id", "arm", "trials", "metrics"],
      "properties": {"arm": {"enum": ["B1", "B2"]}, "trials": {"const": ["r1", "r2", "r3"]}, "metrics": {"type": "object"}}
    },
    "paired_row": {
      "type": "object",
      "required": ["task_id", "trial_id", "delta_direction", "metrics"],
      "properties": {"trial_id": {"enum": ["r1", "r2", "r3"]}, "delta_direction": {"const": "B2-B1"}, "metrics": {"type": "object"}}
    },
    "arm_section": {
      "type": "object",
      "required": ["task_arm_rows", "overall_by_arm"],
      "properties": {
        "task_arm_rows": {"type": "array", "minItems": 28, "maxItems": 28},
        "overall_by_arm": {"type": "array", "minItems": 2, "maxItems": 2}
      }
    }
  }
}
