+
+/// Read committed index bytes from a sealed mmap directory while keeping every lock or
+/// incidental write in memory. Tantivy's reader acquires `META_LOCK` while opening segment
+/// readers, so using `MmapDirectory` directly still requires write access to the index path.
+#[derive(Clone, Debug)]
+struct ImmutableSnapshotDirectory {
+    committed: MmapDirectory,
+    scratch: RamDirectory,
+}
+
+impl ImmutableSnapshotDirectory {
+    fn open(path: &Path) -> Result<Self, String> {
+        Ok(Self {
+            committed: MmapDirectory::open(path).map_err(|e| e.to_string())?,
+            scratch: RamDirectory::create(),
+        })
+    }
+}
+
+impl Directory for ImmutableSnapshotDirectory {
+    fn get_file_handle(&self, path: &Path) -> Result<Arc<dyn FileHandle>, OpenReadError> {
+        match self.scratch.get_file_handle(path) {
+            Ok(handle) => Ok(handle),
+            Err(OpenReadError::FileDoesNotExist(_)) => self.committed.get_file_handle(path),
+            Err(error) => Err(error),
+        }
+    }
+
+    fn delete(&self, path: &Path) -> Result<(), DeleteError> {
+        self.scratch.delete(path)
+    }
+
+    fn exists(&self, path: &Path) -> Result<bool, OpenReadError> {
+        if self.scratch.exists(path)? {
+            return Ok(true);
+        }
+        self.committed.exists(path)
+    }
+
+    fn open_write(&self, path: &Path) -> Result<WritePtr, OpenWriteError> {
+        self.scratch.open_write(path)
+    }
+
+    fn atomic_read(&self, path: &Path) -> Result<Vec<u8>, OpenReadError> {
+        match self.scratch.atomic_read(path) {
+            Ok(data) => Ok(data),
+            Err(OpenReadError::FileDoesNotExist(_)) => self.committed.atomic_read(path),
+            Err(error) => Err(error),
+        }
+    }
+
+    fn atomic_write(&self, path: &Path, data: &[u8]) -> io::Result<()> {
+        self.scratch.atomic_write(path, data)
+    }
+
+    fn sync_directory(&self) -> io::Result<()> {
+        self.scratch.sync_directory()
+    }
+
+    fn acquire_lock(&self, lock: &Lock) -> Result<DirectoryLock, LockError> {
+        self.scratch.acquire_lock(lock)
+    }
+
+    fn watch(&self, callback: WatchCallback) -> tantivy::Result<WatchHandle> {
+        self.scratch.watch(callback)
+    }
+}
 
