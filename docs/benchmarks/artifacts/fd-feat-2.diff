+    /// Compare two entries according to the requested sort key.
+    ///
+    /// Entries whose metadata cannot be read (e.g. broken symlinks) are treated
+    /// as having a size of `0` / the earliest modification time. Ties always fall
+    /// back to the full path so the order stays deterministic.
+    pub fn cmp_by(&self, other: &Self, sort_by: SortBy) -> std::cmp::Ordering {
+        use std::cmp::Ordering;
+        use std::time::SystemTime;
+
+        let by_path = || self.path().cmp(other.path());
+        match sort_by {
+            SortBy::Path => by_path(),
+            SortBy::Name => self
+                .path()
+                .file_name()
+                .cmp(&other.path().file_name())
+                .then_with(by_path),
+            SortBy::Size => {
+                let size = |e: &Self| e.metadata().map(|m| m.len()).unwrap_or(0);
+                size(self).cmp(&size(other)).then_with(by_path)
+            }
+            SortBy::Mtime => {
+                let mtime = |e: &Self| {
+                    e.metadata()
+                        .and_then(|m| m.modified().ok())
+                        .unwrap_or(SystemTime::UNIX_EPOCH)
+                };
+                mtime(self)
+                    .cmp(&mtime(other))
+                    .then_with(by_path)
+                    .then(Ordering::Equal)
+            }
+        }
+    }
 }
 
