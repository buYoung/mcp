+/// --total-count
+#[derive(Debug)]
+struct TotalCount;
+
+impl Flag for TotalCount {
+    fn is_switch(&self) -> bool {
+        true
+    }
+    fn name_long(&self) -> &'static str {
+        "total-count"
+    }
+    fn doc_category(&self) -> Category {
+        Category::Output
+    }
+    fn doc_short(&self) -> &'static str {
+        r"Print the total number of matched lines."
+    }
+    fn doc_long(&self) -> &'static str {
+        r"
+Print the total count of all matched lines across all searched files on a
+single line at the end of the search output. This is distinct from
+\flag{count}, which shows the per-file count. The total count line contains
+only the number.
+.sp
+This flag has no effect when \flag{files}, \flag{files-with-matches} or
+\flag{files-without-match} is passed.
+"
+    }
+
+    fn update(&self, v: FlagValue, args: &mut LowArgs) -> anyhow::Result<()> {
+        args.total_count = v.unwrap_switch();
+        Ok(())
+    }
+}
+
+#[cfg(test)]
+#[test]
+fn test_total_count() {
+    let args = parse_low_raw(None::<&str>).unwrap();
+    assert_eq!(false, args.total_count);
+
+    let args = parse_low_raw(["--total-count"]).unwrap();
+    assert_eq!(true, args.total_count);
+}
+
